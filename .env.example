# Database
DATABASE_URL=postgresql://opensocial_api:your_password_here@localhost:5432/opensocial

# API Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Security - REQUIRED in production
# Generate ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Generate COOKIE_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COOKIE_SECRET=

# OAuth Configuration
SERVICE_URL=http://localhost:3001
PLC_URL=https://plc.directory
PDS_URL=https://bsky.social

# For production, generate JWK keys and set:
# PRIVATE_KEYS=[]

# Legacy
JWT_SECRET=generate_a_random_secret_here
PDS_HOSTNAME=opensocial.community
ADMIN_DID=did:plc:your_admin_did_here